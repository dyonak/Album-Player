[Unit]
Description=Spotifyd - Spotify Connect daemon
After=network-online.target sound.target bluetooth.target dbus.service
Wants=network-online.target sound.target
Requires=dbus.service

[Service]
Type=simple
User=__USER__

# D-Bus and PulseAudio environment for headless operation
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/__UID__/bus
Environment=XDG_RUNTIME_DIR=/run/user/__UID__
Environment=PULSE_RUNTIME_PATH=/run/user/__UID__/pulse

ExecStart=/usr/local/bin/spotifyd --no-daemon --config-path __HOME__/.config/spotifyd/spotifyd.conf
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
