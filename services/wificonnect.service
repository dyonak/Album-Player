[Unit]
Description=Album Player WiFi Provisioning
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/dyonak/album-player
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/python3 -u /home/dyonak/album-player/wificonnect.py
StandardOutput=journal
StandardError=journal
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
